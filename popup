  <script>
    
      const atualURL = window.location.href;
      const urlParams = new URLSearchParams(window.location.search);
      const hasQRCode = urlParams.get("qrcode") === "true";

    const ListaComissoes = {
      "ConselhoAdministracao": "Conselho de Administração",
      "DiretoriaEstatutaria": "Diretoria Estatutária",
      "EstrategiaeInovacao": "Estratégia e Inovação",
      "EticaGovernanca": "Ética e Integridade",
      "EmpresasControleFamiliar": "Famílias Empresárias e Empresas Familiares",
      "FinancasContabilidade": "Finanças, Fiscalização e Controles",
      "GTConselhoFuturo": "Futuro da Governança",
      "SecretariaGovernancaCorporativa": "Governance Officers",
      "AcionistasInvestidores": "Investidores",
      "Juridica": "Jurídica",
      "ComunicacaoMercadoCapitais": "Mercado de Capitais",
      "Pessoas": "Pessoas",
      "GerenciamentoRiscosCorporativos": "Riscos Corporativos",
      "Sustentabilidade": "Sustentabilidade e Clima"
    };

    let ComissaoUsuario = '';
    for (const key in ListaComissoes) {
      if (atualURL.includes(key)) {
        ComissaoUsuario = ListaComissoes[key];
        break;
      }
    }

    (async function () {
      const styleOptions = {
        suggestedActionBackgroundColorOnHover: 'rgb(30, 71, 179)',
        suggestedActionBackgroundColorOnFocus: 'rgb(30, 71, 179)',
        suggestedActionBorderColor: '#1E47B3',
        hideUploadButton: true,
        suggestedActionLayout: 'stacked', // ou 'carousel'
        suggestedActionHeight: '28px', // Reduz a altura dos botões
        suggestedActionTextColor: 'Black',
        suggestedActionTextColorOnHover: 'White',
        suggestedActionTextColorOnFocus: 'White',
        suggestedActionBorderRadius: '14px',
        suggestedActionsStackedLayoutButtonTextWrap: true,
        suggestedActionsStackedLayoutMaxHeight: 200, // Limita a altura total e ativa rolagem
        bubbleMaxWidth: 360, // Garante que as mensagens não fiquem muito largas
        rootHeight: '100%', // Garante que o WebChat ocupe todo o espaço disponível
        botAvatarImage: '/Style%20Library/Images/robot.png',
        fontSizeSmall: '50%',
        botAvatarInitials: '',
        bubbleFromUserBackground: '#1E47B3',
        bubbleFromUserBorderColor: '#1E47B3',
        bubbleFromUserTextColor: 'White',
      };

      const tokenEndpointURL = 'https://ed51e77db4a34cc6a0c990b1f72ab2.e7.environment.api.powerplatform.com/powervirtualagents/botsbyschema/cra86_agent/directline/token?api-version=2022-03-01-preview';
      const locale = document.documentElement.lang || 'pt-BR';
      const apiVersion = '2022-03-01-preview';

      const statusInfo = (msg) => {
        console.log(msg);
        const webchatElem = document.getElementById('webchat');
        if (webchatElem) {
          webchatElem.setAttribute('data-webchat-status', msg);
        }
      };

      const showChatContainer = () => {
        const webchatElem = document.getElementById('webchat');
        if (webchatElem) {
          webchatElem.style.visibility = 'visible';
          webchatElem.style.opacity = '1';
        }
      };

      const hideChatContainer = () => {
        const webchatElem = document.getElementById('webchat');
        if (webchatElem) {
          webchatElem.style.visibility = 'hidden';
          webchatElem.style.opacity = '0';
        }
      };

      hideChatContainer();

      const throwIfNotOK = async (response, name) => {
        if (!response.ok) {
          const text = await response.text().catch(() => 'no body');
          throw new Error(`${name} failed (${response.status} ${response.statusText}): ${text}`);
        }
        return response;
      };

      let directLineURL = 'https://directline.botframework.com';
      try {
        const channelSettings = await fetch(`https://ed51e77db4a34cc6a0c990b1f72ab2.e7.environment.api.powerplatform.com/powervirtualagents/regionalchannelsettings?api-version=${apiVersion}`)
          .then(r => throwIfNotOK(r, 'regionalchannelsettings'))
          .then(r => r.json());

        if (channelSettings?.channelUrlsById?.directline) {
          directLineURL = channelSettings.channelUrlsById.directline;
        } else {
          console.warn('regionalchannelsettings retornou sem directline, usando directline.botframework.com');
        }
      } catch (err) {
        console.warn('Erro em regionalchannelsettings, usando fallback directline.botframework.com', err);
      }

      const tokenData = await fetch(tokenEndpointURL, { method: 'GET' })
        .then(r => throwIfNotOK(r, 'directline token endpoint GET'))
        .then(r => r.json())
        .catch(async (err) => {
          console.warn('GET token endpoint falhou, tentando POST', err);
          return fetch(tokenEndpointURL, { method: 'POST' })
            .then(r => throwIfNotOK(r, 'directline token endpoint POST'))
            .then(r => r.json());
        });

      const token = tokenData?.token || tokenData?.Token;
      if (!token) {
        throw new Error('Token não retornado pelo endpoint de DirectLine. Verificar o canal e a URL.');
      }

      statusInfo('Token DirectLine obtido. Criando DirectLine...');

      const directLine = WebChat.createDirectLine({
        domain: `${new URL('v3/directline', directLineURL)}`,
        token
      });

      const subscription = directLine.connectionStatus$.subscribe({
        next(value) {
          statusInfo(`DirectLine status: ${value}`);
          if (value === 2) {
            showChatContainer();
            directLine.postActivity({
              localTimezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
              locale,
              name: 'startConversation',
              type: 'event',
              value: {
                Comissao: ComissaoUsuario,
                qrcode: hasQRCode
              }
            }).subscribe();
            subscription.unsubscribe();
          }
        }
      });

      WebChat.renderWebChat({ directLine, locale, styleOptions }, document.getElementById('webchat'));
      statusInfo('WebChat renderizado, aguardando conexão...');
    })();
    console.log(hasQRCode)
    console.log(ComissaoUsuario)
    document.getElementById("openPopupIcon").addEventListener("click", () => {
      document.getElementById("popup").style.display = "block";
      document.getElementById("headerMinimizeBtn").style.display = "block";
      document.getElementById("headerCloseBtn").style.display = "block";
      document.querySelector('.triangle').classList.remove('open');
      document.querySelector('.message').classList.remove('open');
      document.querySelector('.ChatCloseButton').classList.remove('open');
    });

    document.getElementById("headerMinimizeBtn").addEventListener("click", () => {
      document.getElementById("popup").style.display = "none";
      document.getElementById("headerMinimizeBtn").style.display = "none";
      document.getElementById("headerCloseBtn").style.display = "none";
      // Show initial tooltip again
      setTimeout(() => {
        document.querySelector('.triangle').classList.add('open');
        document.querySelector('.message').classList.add('open');
        document.querySelector('.ChatCloseButton').classList.add('open');
      }, 300);
    });

    document.getElementById("headerCloseBtn").addEventListener("click", () => {
      document.getElementById("popup").style.display = "none";
      document.getElementById("headerMinimizeBtn").style.display = "none";
      document.getElementById("headerCloseBtn").style.display = "none";
      // Reset to initial state
      setTimeout(() => {
        document.querySelector('.triangle').classList.add('open');
        document.querySelector('.message').classList.add('open');
        document.querySelector('.ChatCloseButton').classList.add('open');
      }, 300);
    });

    document.querySelector('.ChatCloseButton').addEventListener('click', () => {
      document.querySelector('.triangle').classList.remove('open');
      document.querySelector('.message').classList.remove('open');
      document.querySelector('.ChatCloseButton').classList.remove('open');
    });

    window.addEventListener('load', () => {
      // Começa fechado no load e exibe apenas o ícone de abrir.
      document.getElementById('popup').style.display = 'none';
      document.getElementById('headerMinimizeBtn').style.display = 'none';
      document.getElementById('headerCloseBtn').style.display = 'none';
      document.querySelector('.triangle').classList.add('open');
      document.querySelector('.message').classList.add('open');
      document.querySelector('.ChatCloseButton').classList.add('open');
    });
  </script>
